#!/bin/sh
# Randomise buildorder.py test on packages directory

export TERMUX_SCRIPTDIR
TERMUX_SCRIPTDIR=$(realpath "$(dirname "$0")/../..") # Root of repository.

cd "${TERMUX_SCRIPTDIR}" || exit 1

no_of_total_packages=0

total_packages=$(find packages x11-packages -mindepth 1 -maxdepth 1 -type d | sort)

[ -n "${total_packages}" ] && no_of_total_packages=$(echo "${total_packages}" | wc -l)

for repo in $(jq --raw-output 'del(.pkg_format) | keys | .[]' repo.json); do
  REPOSITORY_NAME=$(jq --raw-output '.["'$repo'"].name' repo.json)
  REPOSITORY_DISTRIBUTION=$(jq --raw-output '.["'$repo'"].distribution' repo.json)
  REPOSITORY_COMPONENT=$(jq --raw-output '.["'$repo'"].component' repo.json)
  REPOSITORY_URL=$(jq --raw-output '.["'$repo'"].url' repo.json)
  # aarch64 is the primary architecture - there are no packages which have aarch64 in TERMUX_PKG_EXCLUDED_ARCHES
  [ -f $REPOSITORY_NAME.pkglist ] || \
    curl -L "$REPOSITORY_URL/dists/$REPOSITORY_DISTRIBUTION/$REPOSITORY_COMPONENT/binary-aarch64/Packages" \
      -o $REPOSITORY_NAME.pkglist >/dev/null || exit 1
done

no_of_built_packages=0

for pkg in ${total_packages}; do
  pkg=$(basename ${pkg})
  if grep "^Package: ${pkg}$" *.pkglist >/dev/null; then
    no_of_built_packages=$(expr ${no_of_built_packages} + 1)
    continue
  fi
  echo "${pkg}"
done

echo "Built ${no_of_built_packages} packages out of ${no_of_total_packages}"
